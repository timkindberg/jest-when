{
  "name": "jest-when-jest27-compat",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist dist-test",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "jest --config ./jest.config.cjs --runInBand",
    "verify": "npm run clean && npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@types/jest": "^27.5.2",
    "@types/node": "^24.3.1",
    "expect-type": "^1.3.0",
    "jest": "^27.5.1",
    "jest-mock-extended": "^3.0.7",
    "ts-jest": "^27.1.5",
    "typescript": "^4.9.5"
  }
}
