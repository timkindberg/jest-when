{
  "name": "jest-when",
  "version": "3.8.1-4",
  "description": "An extension lib for jest",
  "license": "MIT",
  "main": "dist/when.js",
  "types": "dist/when.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build",
    "test": "jest",
    "lint": "eslint src/",
    "lint.fix": "eslint src/ --fix",
    "stryker": "stryker run",
    "release": "np",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timkindberg/jest-when/"
  },
  "contributors": [
    "Tim Kindberg <timkindberg@gmail.com>",
    "Jonas Holtkamp <jonas.holtkamp@senacor.com>"
  ],
  "peerDependencies": {
    "jest": ">= 25"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@stryker-mutator/core": "^2.0.0",
    "@stryker-mutator/html-reporter": "^2.0.0",
    "@stryker-mutator/javascript-mutator": "^2.0.0",
    "@stryker-mutator/jest-runner": "^2.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.1",
    "eslint": "^4.19.1",
    "eslint-config-standard": "^11.0.0",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-node": "^6.0.1",
    "eslint-plugin-promise": "^3.7.0",
    "eslint-plugin-standard": "^3.1.0",
    "expect-type": "^1.3.0",
    "jest": "^27.0.0",
    "jest-mock-extended": "^4.0.0",
    "np": "^7.3.0",
    "pre-commit": "^1.2.2",
    "ts-jest": "^27.1.4",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "verbose": false,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts"
    ],
    "coverageDirectory": "build/reports/coverage/",
    "coverageReporters": [
      "html",
      "lcov",
      "text"
    ],
    "testMatch": [
      "**/src/**/*.test.ts"
    ],
    "resetModules": true
  },
  "pre-commit": [
    "lint",
    "test"
  ]
}
